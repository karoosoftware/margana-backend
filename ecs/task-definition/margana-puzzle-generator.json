{
  "family": "margana-puzzle-generator",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "256",
  "memory": "512",
  "executionRoleArn": "arn:aws:iam::992468223519:role/ecsTaskExecutionRole",
  "taskRoleArn": "arn:aws:iam::992468223519:role/margana-puzzle-generator-task-role",
  "containerDefinitions": [
    {
      "name": "margana-puzzle-generator",
      "image": "992468223519.dkr.ecr.eu-west-2.amazonaws.com/margana-preprod:latest",
      "essential": true,
      "command": ["--smoke-test"],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/margana-puzzle-generator",
          "awslogs-region": "eu-west-2",
          "awslogs-stream-prefix": "ecs"
        }
      }
    }
  ]
}